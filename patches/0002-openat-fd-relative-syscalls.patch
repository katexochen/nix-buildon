@@ -0,0 +1,118 @@
+#!/bin/sh
+# Test multi-user mode with an unreachable intermediate directory.
+#
+# Simulates the Nix sandbox pattern: a root-owned 0700 directory
+# contains a subdirectory owned by another user.  The other user
+# must be able to access their own subdirectory even though they
+# cannot traverse the intermediate directory on the backing FS.
+#
+# Requires root.
+
+set -eu
+
+if [ "$(id -u)" -ne 0 ]; then
+	echo "SKIP (requires root)"
+	exit 0
+fi
+
+# Pick a UID that exists (nobody = 65534)
+TEST_UID=65534
+TEST_GID=65534
+
+SRCDIR="$(mktemp -d)"
+MNTDIR="$(mktemp -d)"
+trap 'fusermount -q -z -u "$MNTDIR" 2>/dev/null; rm -rf "$SRCDIR" "$MNTDIR"' EXIT
+
+# Set up the backing directory structure:
+#   src/             (root:root 0700)
+#   src/restricted/  (root:root 0700) -- unreachable by TEST_UID
+#   src/restricted/work/ (TEST_UID:TEST_GID 0700) -- owned by test user
+chmod 0700 "$SRCDIR"
+mkdir -p "$SRCDIR/restricted/work"
+chmod 0700 "$SRCDIR/restricted"
+chown "$TEST_UID:$TEST_GID" "$SRCDIR/restricted/work"
+chmod 0700 "$SRCDIR/restricted/work"
+
+../disorderfs -q --multi-user=yes --sort-dirents=yes "$SRCDIR" "$MNTDIR"
+
+Fail () {
+	echo "E: ${*}"
+	exit 1
+}
+
+# The test user accesses their own directory through the FUSE mount.
+# The intermediate "restricted/" directory is root:root 0700 on the
+# backing FS, but resolve_target walks it as root.
+python3 -c "
+import os, sys, errno
+
+os.setgroups([])
+os.setegid($TEST_GID)
+os.seteuid($TEST_UID)
+
+base = '$MNTDIR/restricted/work'
+
+# stat
+try:
+    st = os.stat(base)
+except OSError as e:
+    print('stat failed: ' + str(e), file=sys.stderr)
+    sys.exit(1)
+
+# create file
+path = os.path.join(base, 'testfile')
+try:
+    fd = os.open(path, os.O_CREAT | os.O_WRONLY, 0o644)
+    os.write(fd, b'hello')
+    os.close(fd)
+except OSError as e:
+    print('create failed: ' + str(e), file=sys.stderr)
+    sys.exit(1)
+
+# read back
+try:
+    fd = os.open(path, os.O_RDONLY)
+    data = os.read(fd, 100)
+    os.close(fd)
+    assert data == b'hello', 'read mismatch'
+except OSError as e:
+    print('read failed: ' + str(e), file=sys.stderr)
+    sys.exit(1)
+
+# chmod
+try:
+    os.chmod(path, 0o755)
+except OSError as e:
+    print('chmod failed: ' + str(e), file=sys.stderr)
+    sys.exit(1)
+
+# listdir
+try:
+    entries = os.listdir(base)
+    assert 'testfile' in entries, 'missing testfile in listdir'
+except OSError as e:
+    print('listdir failed: ' + str(e), file=sys.stderr)
+    sys.exit(1)
+
+# mkdir + rmdir
+subdir = os.path.join(base, 'subdir')
+try:
+    os.mkdir(subdir, 0o755)
+    os.rmdir(subdir)
+except OSError as e:
+    print('mkdir/rmdir failed: ' + str(e), file=sys.stderr)
+    sys.exit(1)
+
+# rename
