-        // NEEDS TEST: flags may be RENAME_EXCHANGE and RENAME_NOREPLACE
-        Guard g;
-        return wrap(rename((root + oldpath).c_str(), (root + newpath).c_str()));
+        ResolvedPath rp_old = resolve_parent(oldpath);
+        if (rp_old.parent_fd == -1) return -errno;
