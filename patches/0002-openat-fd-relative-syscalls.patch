+// Resolve a FUSE path to parent directory fd, leaf name, and optionally
+// an O_PATH fd to the target itself.  The entire walk (including the
+// leaf lookup for the target fd) is done as root so that intermediate
+// directories the caller cannot search do not cause spurious EACCES.
+//
+// Operations that ACCESS the target (stat, opendir, xattr, …) should
+// use target_fd.  Operations that CREATE/DELETE in the parent (mkdir,
+// unlink, …) should use parent_fd + leaf.
+struct ResolvedPath {
+    int parent_fd;        // O_PATH fd to the leaf's parent directory
+    int target_fd;        // O_PATH fd to the target itself, or -1
+    std::string leaf;
+    bool parent_needs_close;
+    bool target_needs_close;
+
+    void close_all () {
+        if (target_needs_close && target_fd >= 0) { close(target_fd); target_fd = -1; }
+        if (parent_needs_close && parent_fd >= 0) { close(parent_fd); parent_fd = -1; }
+    }
+};
+
+// Walk all path components as root, returning parent_fd + leaf.
+// Does NOT open target_fd; call resolve_target() for that.
+ResolvedPath resolve_parent (const char* fuse_path)
+{
+    const char* p = fuse_path;
+    if (*p == '/') p++;
+
+    if (*p == '\0') {
+        return {root_fd, -1, "", false, false};
+    }
+
+    std::vector<std::string> components;
+    std::string remaining(p);
+    size_t pos;
+    while ((pos = remaining.find('/')) != std::string::npos) {
+        components.push_back(remaining.substr(0, pos));
+        remaining = remaining.substr(pos + 1);
+    }
+
+    if (components.empty()) {
+        return {root_fd, -1, remaining, false, false};
+    }
+
+    std::string leaf = remaining;
+    int current_fd = root_fd;
+    bool current_needs_close = false;
+    for (const auto& comp : components) {
+        int next_fd = openat(current_fd, comp.c_str(),
+                             O_PATH | O_NOFOLLOW | O_DIRECTORY | O_CLOEXEC);
+        if (next_fd == -1) {
+            if (current_needs_close) close(current_fd);
+            return {-1, -1, "", false, false};
+        }
+        if (current_needs_close) close(current_fd);
+        current_fd = next_fd;
+        current_needs_close = true;
+    }
+    return {current_fd, -1, leaf, current_needs_close, false};
+}
+
+// Resolve the full path including the leaf.  Returns both parent_fd
+// (for namespace operations) and target_fd (for operations on the
+// target itself).  Both are obtained as root.
+ResolvedPath resolve_target (const char* fuse_path)
+{
+    ResolvedPath rp = resolve_parent(fuse_path);
+    if (rp.parent_fd == -1) return rp;
+
+    if (rp.leaf.empty()) {
+        // Root path: target IS root_fd
+        rp.target_fd = root_fd;
+        rp.target_needs_close = false;
+        return rp;
+    }
+
+    rp.target_fd = openat(rp.parent_fd, rp.leaf.c_str(),
+                          O_PATH | O_NOFOLLOW | O_CLOEXEC);
+    if (rp.target_fd == -1) {
+        int err = errno;
+        rp.close_all();
+        rp.parent_fd = -1;
+        errno = err;
+        return rp;
+    }
+    rp.target_needs_close = true;
+    return rp;
+}
+
